# Johnethel Lessons — Environment Variables
# Copy to .env and fill in values, then run: source .env && golem deploy -Y

# Authentik OIDC
AUTHENTIK_URL="https://auth.johnethel.school"
AUTHENTIK_CLIENT_ID="rhca5hupVGwRWh2EVf7dkw3WXXFcseJMcsdQYVH9"
AUTHENTIK_USERINFO_URL="https://auth.johnethel.school/application/o/userinfo/"

# SurrealDB
SURREALDB_URL="http://localhost:8000"
SURREALDB_NS="johnethel"
SURREALDB_DB="lessons"
SURREALDB_USER="root"
SURREALDB_TOKEN="root"
# If SURREALDB_USER is empty, Bearer token auth is used instead of Basic auth
# Production: set a scope-limited token, leave USER empty for Bearer auth

# API (static component serves this to frontend)
API_URL="http://johnethel-lessons-app.localhost:9006"
